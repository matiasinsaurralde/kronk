    {
      "id": "4zc_WtvvGB67--h93YMWU",
      "type": "text",
      "x": -1911.1121791137616,
      "y": -1076.8634189249856,
      "width": 222.6464843749999,
      "height": 225,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bCq",
      "roundness": null,
      "seed": 276697567,
      "version": 586,
      "versionNonce": 383706822,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1778542715985,
      "link": null,
      "locked": false,
      "text": "Rule of thumb (Q4–Q8):\n\n• 8 GB → ~1B params\n\n• 16 GB → 3–7B params\n\n• 32 GB+ → 7–14B easy\n\nGPU VRAM sets the\nreal ceiling.",
      "fontSize": 18,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Rule of thumb (Q4–Q8):\n\n• 8 GB → ~1B params\n\n• 16 GB → 3–7B params\n\n• 32 GB+ → 7–14B easy\n\nGPU VRAM sets the\nreal ceiling.",
      "autoResize": false,
      "lineHeight": 1.25
    },
