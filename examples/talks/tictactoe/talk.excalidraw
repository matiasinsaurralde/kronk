    {
      "id": "m8C2H9fexjSB2f5nQiyQW",
      "type": "text",
      "x": -2215.6906474365155,
      "y": -1076.8634189249856,
      "width": 201.80342102050784,
      "height": 202.5,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bCn",
      "roundness": null,
      "seed": 1083749759,
      "version": 707,
      "versionNonce": 520533466,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1778542596970,
      "link": null,
      "locked": false,
      "text": "Shrink the weights:\n\n• FP16 → full quality\n• Q8 → ½ size, ~same\n• Q4 → ¼ size, OK\n\nTrade a little quality\nfor a lot of speed\nand memory.",
      "fontSize": 18,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Shrink the weights:\n\n• FP16 → full quality\n• Q8 → ½ size, ~same\n• Q4 → ¼ size, OK\n\nTrade a little quality\nfor a lot of speed\nand memory.",
      "autoResize": false,
      "lineHeight": 1.25
    },
